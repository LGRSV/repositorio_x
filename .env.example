# Obrigatório. Use uma senha longa exclusiva para permitir novos uploads.
ADMIN_UPLOAD_PASSWORD=troque-por-uma-senha-administrativa-longa

# Opcional: só preencha depois que publicar em domínio com HTTPS.
PUBLIC_BASE_URL=https://arquivos.seudominio.com
COOKIE_SECURE=true

# Ajustes operacionais opcionais.
MAX_UPLOAD_MB=12
SESSION_TTL_HOURS=24

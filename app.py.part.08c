in-top:24px;padding:14px;background:rgba(126,200,255,.055);border-left:2px solid var(--accent2);color:#b4c3ce;font-size:11px;line-height:1.6}.security-note strong{color:#e2f0f8}.capabilities{display:grid;grid-template-columns:repeat(4,1fr);margin-top:18px;border:1px solid var(--line);border-radius:14px;overflow:hidden;background:rgba(13,17,21,.72)}.capabilities div{padding:17px 19px;border-right:1px solid var(--line)}.capabilities div:last-child{border:0}.capabilities span,.result-row>span,.viewer-label{display:block;font:700 9px var(--mono);color:var(--dim);letter-spacing:.1em;margin-bottom:7px}.capabilities b{font-size:13px;letter-spacing:-.02em}footer{max-width:1100px;margin:0 auto;padding:24px 28px 30px;color:var(--dim);font:10px var(--mono);letter-spacing:.07em}.notice{max-width:640px
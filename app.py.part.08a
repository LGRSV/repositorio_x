:root{--bg:#080a0d;--panel:#11151a;--panel2:#161c23;--line:#27313b;--line2:#364452;--ink:#f3f7f8;--muted:#95a3ae;--dim:#64727d;--accent:#8cffb1;--accent2:#7ec8ff;--danger:#ff8a8a;--sans:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;--mono:"SFMono-Regular",Consolas,"Liberation Mono",monospace}*{box-sizing:border-box}html{min-height:100%;background:var(--bg)}body{margin:0;min-height:100vh;background:radial-gradient(800px 500px at 8% -5%,#183127 0,transparent 58%),radial-gradient(700px 420px at 100% 0,#16293d 0,transparent 54%),var(--bg);font-family:var(--sans);color:var(--ink);letter-spacing:-.01em}.noise{position:fixed;inset:0;pointer-events:none;opacity:.17;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.6'/%3E%3C/svg%3E");z-index:0}.site-header,.wrap,footer,.viewer-main{position:relative;z-index:1}.site-header{height:72px;display:flex;justify-content:space-between;align-items:center;padding:0 clamp(20px,5vw,76px);border-bottom:1px solid rgba(149,163,174,.18);background:rgba(8,10,13,.62);backdrop-filter:blur(12px)}.brand{text-decoration:none;color:var(--ink);font:700 16px var(--mono);letter-spacing:-.06em;display:flex;align-items:center;gap:10px}.brand span{font-size:12px;letter-spacing:-.1em;background:var(--accent);color:#07100a;border-radius:5px;padding:5px 6px}.header-status{font:10px var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:.11em;display:flex;align-items:center;gap:7px}.header-status i{display:block;width:7px;height:7px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 4px rgba(140,255,177,.11)}.wrap{max-width:1100px;margin:0 auto;padding:72px 28px 48px}.hero{max-width:720px;margin-bottom:42px}.eyebrow{color:var(--accent2);font:700 10px var(--mono);letter-spacing:.16em;text-transform:uppercase;margin-bottom:16px}.eyebrow.good{color:var(--accent)}h1{margin:0;color:#f7fbfb;font-size:clamp(37px,6vw,72px);letter-spacing:-.055em;line-height:.98;font-weight:700}h1 em{font-family:Georgia,serif;font-weight:400;color:var(--accent);letter-spacing:-.08em}.hero p,.gate-shell>p,.result-intro,.empty-state p{font-size:16px;line-height:1.65;color:var(--muted);max-width:640px;margin:24px 0 0}.upload-grid{display:grid;grid-template-columns:min
;margin:40px auto;padding:16px 18px;border:1px solid var(--line2);border-radius:10px;background:#10161d;color:#d4e2e8;font-size:13px;line-height:1.55}.notice.error,.warning.error{border-color:rgba(255,138,138,.5);background:rgba(91,23,23,.25);color:#ffb5b5}.result-shell,.gate-shell,.empty-state{max-width:760px;margin:40px auto;padding:18px 0 40px}.result-card{margin-top:30px;border:1px solid var(--line);border-radius:16px;overflow:hidden;background:rgba(13,18,22,.93)}.result-row{padding:19px 20px;border-bottom:1px solid var(--line)}.result-row:last-child{border:0}.result-row>b{display:block;font-size:15px}.copy-line{display:flex;gap:9px}.copy-line input{margin:0;border-color:#2c3c4c;background:#0a1015;font:12px var(--mono);color:#d4e6ef}.copy-line button{margin:0;border:1px solid #486176;background:#192b37;color:#d7edf7;font:700 11px var(--mono);border-radius:7px;padding:0 13px;cursor:pointer}.copy-line button:hover{background:#234052}.warning{margin-top:14px;border:1px solid rgba(255,205,118,.38);background:rgba(91,65,20,.18);border-radius:10px;padding:13px 15px;color:#e7d7af;font-size:12px;line-height:1.55}.warning strong{color:#fff0c4}.action-row{display:flex;gap:10px;margin-top:23px;align-items:center}.link-button{width:auto}.file-mark{display:grid;place-items:center;width:46px;height:46px;border:1px solid #3f7187;border-radius:12px;color:var(--accent2);background:rgba(126,200,255,.08);font:700 17px var(--mono);margin-bottom:20px}.gate-shell{max-width:550px;margin-top:66px}.gate-shell h1{font-size:clamp(30px,5vw,48px);line-height:1.05;overflow-wrap:anywhere}.gate-form{margin-top:26px;padding:24px}.file-meta{margin-top:17px;color:var(--dim);font:10px var(--mono);line-height:1.55}.empty-state{text-align:center;max-width:520px}.empty-state .file-mark{margin:0 auto 20px}.empty-state h1{font-size:40px}.empty-state .secondary{margin-top:25px}.viewer-page{height:100vh;overflow:hidden;background:#0a0d10}.viewer-main{height:calc(100vh - 72px);padding:0}.viewer{height:100%;display:flex;flex-direction:column}.viewer-bar{min-height:61px;display:flex;justify-content:space-between;align-items:center;padding:11px clamp(18px,4vw,55px);border-bottom:1px solid var(--line);background:#0d1217}.viewer-bar b{font-size:13px;color:#e7eff1;display:block;white-space:nowrap;max-width:55vw;overflow:hidden;text-overflow:ellipsis}.viewer-actions{display:flex;gap:9px;align-items:center}.viewer-actions form{margin:0}.viewer-link{padding:9px 10px;color:#b6c7ce;border:1px solid #2c3b48
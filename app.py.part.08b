max(0,1.3fr) minmax(300px,.7fr);gap:18px}.panel{background:linear-gradient(145deg,rgba(22,28,35,.95),rgba(13,17,21,.94));border:1px solid var(--line);border-radius:17px;box-shadow:0 24px 72px rgba(0,0,0,.22)}.form-panel{padding:28px}.info-panel{padding:28px;background:linear-gradient(155deg,rgba(18,31,32,.87),rgba(14,18,22,.95))}.panel-head{display:flex;gap:13px;align-items:flex-start;margin-bottom:26px}.panel-head>span{font:700 10px var(--mono);color:var(--accent);border:1px solid rgba(140,255,177,.35);background:rgba(140,255,177,.06);border-radius:50%;width:25px;height:25px;display:grid;place-items:center;flex:0 0 auto}.panel-head h2{font-size:16px;letter-spacing:-.025em;margin:1px 0 5px}.panel-head p{font-size:12px;color:var(--muted);line-height:1.4;margin:0}form label{display:block;font:700 11px var(--mono);letter-spacing:.03em;color:#dfe9eb;margin:0 0 17px}input{font:14px var(--sans);letter-spacing:0;width:100%;margin-top:8px;padding:12px 13px;border:1px solid var(--line2);border-radius:8px;background:#090c10;color:var(--ink);outline:none;transition:.16s border-color,.16s box-shadow}input:focus{border-color:var(--accent2);box-shadow:0 0 0 3px rgba(126,200,255,.11)}input[type=file]{padding:9px 10px;color:var(--muted);cursor:pointer}input[type=file]::file-selector-button{border:0;border-radius:5px;padding:6px 9px;background:#243241;color:#dcedf4;font:700 10px var(--mono);margin-right:9px;cursor:pointer}small{display:block;color:var(--dim);font:10px var(--mono);line-height:1.45;margin-top:7px;font-weight:400}.muted{color:var(--dim);font-weight:400}.primary,.secondary,.viewer-link{font:700 12px var(--mono);letter-spacing:.01em;border:0;cursor:pointer;text-decoration:none;display:inline-flex;justify-content:center;align-items:center;gap:22px;border-radius:8px;transition:transform .16s,filter .16s}.primary{width:100%;padding:14px 16px;color:#08110b;background:var(--accent);margin-top:4px}.primary:hover{filter:brightness(1.08);transform:translateY(-1px)}.primary span{font-size:17px;line-height:.5}.secondary{padding:13px 16px;color:#d7e1e4;border:1px solid var(--line2);background:rgba(15,19,24,.74)}.secondary:hover{background:#1d252e}.steps{list-style:none;padding:0;margin:0;display:grid;gap:0}.steps li{padding:15px 0;border-top:1px solid rgba(149,163,174,.17);display:grid;grid-template-columns:80px 1fr;gap:9px;font-size:12px;line-height:1.45}.steps b{font-family:var(--mono);font-size:10px;color:var(--accent)}.steps span{color:var(--muted)}.security-note{marg
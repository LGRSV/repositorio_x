BASE_DIR = Path(__file__).resolve().parent
DATA_DIR = Path(os.environ.get("DATA_DIR", BASE_DIR / "data")).resolve()
UPLOAD_DIR = DATA_DIR / "uploads"
DB_PATH = DATA_DIR / "repository_x.sqlite3"

ADMIN_UPLOAD_PASSWORD = os.environ.get("ADMIN_UPLOAD_PASSWORD", "")
if not ADMIN_UPLOAD_PASSWORD:
    raise RuntimeError(
        "ADMIN_UPLOAD_PASSWORD não configurada. Defina uma senha forte antes de iniciar o repository_x."
    )

PORT = int(os.environ.get("PORT", "8080"))
MAX_UPLOAD_MB = int(os.environ.get("MAX_UPLOAD_MB", "12"))
MAX_UPLOAD_BYTES = MAX_UPLOAD_MB * 1024 * 1024
SESSION_TTL_HOURS = max(1, int(os.environ.get("SESSION_TTL_HOURS", "24")))
PUBLIC_BASE_URL = os.environ.get("PUBLIC_BASE_URL", "").strip().rstrip("/")
COOKIE_SECURE = os.environ.get("COOKIE_SECURE", "").lower() in {"1", "true", "yes"}

# Evita caracteres fáceis de confundir visualmente em senhas e identificadores.
ALPHABET = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"
TITLE_RE = re.compile(r"<title[^>]*>(.*?)</title\s*>", re.I | re.S)


def utc_now() -> datetime:
    return datetime.now(timezone.utc)


def iso(dt: datetime) -> str:
    return dt.astimezone(timezone.utc).isoformat()


def clean_text(value: str, max_len: int = 140) -> str:
    value = re.sub(r"\s+", " ", value or "").strip()
    return value[:max_len]


def safe_filename(name: str) -> str:
    name = Path(name or "arquivo.html").name
    name = re.sub(r"[^\w.\-() ]+", "_", name, flags=re.UNICODE)
    return (name[:140] or "arquivo.html")


def extract_html_title(raw: bytes) -> str:
    sample = raw[:120_000].decode("utf-8", errors="ignore")
    match = TITLE_RE.search(sample)
    if not match:
        return "Arquivo HTML compartilhado"
    title = clean_text(html.unescape(re.sub(r"<[^>]+>", "", match.group(1))), 100)
    return title or "Arquivo HTML compartilhado"


def generate_share_id() -> str:
    return "".join(secrets.choice(ALPHABET.lower()) for _ in range(12))


def generate_access_password() -> str:
    chunks = []
    for _ in range(4):
        chunks.append("".join(secrets.choice(ALPHABET) for _ in range(4)))
    return "-".join(chunks)


def hash_password(password: str) -> str:
    """Hash scrypt com salt aleatório; nada de senha em texto puro no banco."""
    salt = secrets.token_bytes(16)
    key = hashlib.scrypt(
        password.encode("utf-8"), salt=salt, n=2**14, r=8, p=1, dklen=32
    )
    return "scrypt$16384$8$1${}${}".format(
        base64.urlsafe_b64encode(salt).decode("ascii"),
        base64.urlsafe_b64encode(key).decode("ascii"),
    )


def verify_password(password: str, encoded: str) -> bool:
    try:
        algorithm, n, r, p, salt64, key64 = encoded.split("$")
        if algorithm != "scrypt":
            return False
        salt = base64.urlsafe_b64decode(salt64.encode("ascii"))
        expected = base64.urlsafe_b64decode(key64.encode("ascii"))
        actual = hashlib.scrypt(
            password.encode("utf-8"),
            salt=salt,
            n=int(n),
            r=int(r),
            p=int(p),
            dklen=len(expected),
        )
        return hmac.compare_digest(actual, expected)
    except Exception:
        return False


class Store:
    def __init__(self, db_path: Path) -> None:
        self.db_path = db_path
        self.lock = threading.RLock()
        self._init_db()

    def _conn(self) -> sqlite3.Connection:
        conn = sqlite3.connect(self.db_path, timeout=15, check_same_thread=False)
        conn.row_factory = sqlite3.Row
        return conn

    def _init_db(self) -> None:
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        UPLOAD_DIR.mkdir(parents=True, exist_ok=True)
        with self.lock, self._conn() as conn:
            conn.executescript(
                """
                PRAGMA journal_mode=WAL;
                PRAGMA foreign_keys=ON;

                CREATE TABLE IF NOT EXISTS files (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    share_id TEXT NOT NULL UNIQUE,
                    title TEXT NOT NULL,
                    original_name TEXT NOT NULL,
                    stored_name TEXT NOT NULL UNIQUE,
                    password_hash TEXT NOT NULL,
                    size_bytes INTEGER NOT NULL,
                    created_at TEXT NOT NULL,
                    last_access_at TEXT
                );

                CREATE TABLE IF NOT EXISTS sessions (
                    token_hash TEXT PRIMARY KEY,
                    payload TEXT NOT NULL,
                    expires_at TEXT NOT NULL,
                    updated_at TEXT NOT NULL
                );

                CREATE INDEX IF NOT EXISTS idx_sessions_expiry ON sessions(expires_at);
                """
            )

    def cleanup(self) -> None:
        now = iso(utc_now())
        with self.lock, self._conn() as conn:
            conn.execute("DELETE FROM sessions WHERE expires_at < ?", (now,))

